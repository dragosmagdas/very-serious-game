[sub_resource type="GDScript" id="GDScript_jmsu8"]
script/source = "extends Resource
class_name SpeedUpgrade

@export var texture: Texture2D = preload(\"res://Sprites/BulletSpeedUpgrade.png\")
@export var increase:int = 100
@export var description:String

func apply_upgrade(bullet):
	bullet.speed += increase
"

